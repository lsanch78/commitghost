{
  "name": "commitghost",
  "version": "0.2.0",
  "description": "AI-powered commit message suggestions from your staged diff, right in the terminal.",
  "type": "module",
  "bin": {
    "commitghost": "dist/cli.js",
    "commitg": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "cli",
    "llm"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "openai": "^4.73.0",
    "@clack/prompts": "^0.8.2",
    "commander": "^12.1.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
